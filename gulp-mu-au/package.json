{
  "name": "gulp-mu-au",
  "version": "0.1.1",
  "description": "microAU - Node module to build sound atlases (one combined audio blob + JSON timing map) for the microCSS family, on top of gulp-mu-sound-atlas.",
  "type": "module",
  "main": "src/index.mjs",
  "exports": {
    ".": "./src/index.mjs"
  },
  "files": [
    "src",
    "docs",
    "README.md"
  ],
  "scripts": {
    "test": "mocha test/**/*.test.mjs"
  },
  "keywords": [
    "gulp",
    "sound",
    "audio",
    "atlas",
    "sprite",
    "wav",
    "mp3"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mamekudz/microCSS.git",
    "directory": "gulp-mu-au"
  },
  "homepage": "https://github.com/mamekudz/microCSS/tree/master/gulp-mu-au#readme",
  "bugs": {
    "url": "https://github.com/mamekudz/microCSS/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "gulp-mu-sound-atlas": "^1.0.0",
    "vinyl": "^3.0.1"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "mocha": "^11.7.6"
  }
}
