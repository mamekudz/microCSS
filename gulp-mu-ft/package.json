{
  "name": "gulp-mu-ft",
  "version": "0.1.3",
  "description": "microFT - Node module to generate icon fonts (SVG/TTF/EOT/WOFF/WOFF2) plus ready-to-use CSS classes, an IcoMoon-compatible JSON and an HTML overview from a directory of SVG glyphs.",
  "type": "module",
  "main": "src/index.mjs",
  "exports": {
    ".": "./src/index.mjs"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "mocha test/**/*.test.mjs"
  },
  "keywords": [
    "gulp",
    "font",
    "icon",
    "icomoon",
    "svg",
    "ttf",
    "woff",
    "woff2",
    "css"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mamekudz/microCSS.git",
    "directory": "gulp-mu-ft"
  },
  "homepage": "https://github.com/mamekudz/microCSS/tree/master/gulp-mu-ft#readme",
  "bugs": {
    "url": "https://github.com/mamekudz/microCSS/issues"
  },
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {
    "svg2ttf": "^6.1.0",
    "svgicons2svgfont": "^15.0.1",
    "ttf2eot": "^3.1.0",
    "ttf2woff": "^3.0.0",
    "ttf2woff2": "^8.0.1"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "mocha": "^11.7.6"
  }
}
